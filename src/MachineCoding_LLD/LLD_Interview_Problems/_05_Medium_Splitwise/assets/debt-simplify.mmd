    classDef cre fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef loop fill:#e0f0ff,stroke:#0366d6,color:#023;
    classDef step fill:#f3f8ff,stroke:#0366d6,color:#023;
    classDef ok fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
