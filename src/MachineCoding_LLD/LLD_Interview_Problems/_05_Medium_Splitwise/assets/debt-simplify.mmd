%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    RAW["Raw pairwise debts (many edges)<br/>collapse each person to a single NET position"]:::hdr

    NET["<b>net balances</b> (sum = 0 by conservation)<br/>A = −30 · B = +15 · C = −25 · D = +40"]:::net

    subgraph HEAPS["split by sign into two max-heaps (by magnitude)"]
        direction LR
        DEB["<b>debtors</b> (owe)<br/>A:30 · C:25"]:::deb
        CRE["<b>creditors</b> (owed)<br/>D:40 · B:15"]:::cre
    end

    LOOP["<b>greedy loop</b>: match largest debtor ↔ largest creditor,<br/>settle min(the two), push back the remainder"]:::loop

    subgraph TRACE["worked trace"]
        direction TB
        S1["A:30 ↔ D:40 → <b>A pays D 30</b>; D:10 left"]:::step
        S2["C:25 ↔ B:15 → <b>C pays B 15</b>; C:10 left"]:::step
        S3["C:10 ↔ D:10 → <b>C pays D 10</b>; both cleared"]:::step
        S1 --> S2 --> S3
    end

    RESULT["3 transactions for 4 people (≤ n−1),<br/>down from the raw pairwise edges"]:::ok

    RAW --> NET --> HEAPS --> LOOP --> TRACE --> RESULT

    NOTE["Greedy is near-optimal and O(n log n); the ABSOLUTE minimum number of<br/>transactions is NP-hard (a subset-sum / partition problem) — say so, don't fake optimality."]:::note
    RESULT --> NOTE

