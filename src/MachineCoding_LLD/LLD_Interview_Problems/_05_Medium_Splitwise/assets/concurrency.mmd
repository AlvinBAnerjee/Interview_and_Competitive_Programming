%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    subgraph Threads["Many threads adding expenses concurrently"]
        direction LR
        T1["addExpense<br/>(A pays, B owes)"]
        T2["addExpense<br/>(C pays, D owes)"]
        T3["addExpense<br/>(A pays, B owes)"]
    end

    BS{{"BalanceSheet<br/>ConcurrentHashMap&lt;PairKey, Long&gt;<br/><b>one signed entry per user-pair</b>"}}:::bs

    T1 --> BS
    T2 --> BS
    T3 --> BS

    subgraph E1["entry (A,B)"]
        M1["merge(+share)<br/>atomic read-modify-write"]:::merge
    end
    subgraph E2["entry (C,D)"]
        M2["merge(+share)<br/>atomic"]:::merge
    end

    BS -->|"pair (A,B): threads 1 & 3"| M1
    BS -->|"pair (C,D): thread 2"| M2

    NOTE["Each debt = ONE signed entry, so an update is a single atomic merge — no lost updates,<br/>and NO two rows to keep in sync → no multi-lock, no lock ordering, no deadlock.<br/>Entries are self-balancing, so Σ of all balances is EXACTLY 0 at every instant, any interleaving.<br/>(If a design instead needed to lock several users at once: sort by id for a consistent order.)"]:::note

    E1 --> NOTE
    E2 --> NOTE

    classDef bs fill:#eef2ff,stroke:#3949ab,color:#1a237e;
    classDef merge fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef note fill:#fff8e1,stroke:#f9a825,color:#7a5a00;
