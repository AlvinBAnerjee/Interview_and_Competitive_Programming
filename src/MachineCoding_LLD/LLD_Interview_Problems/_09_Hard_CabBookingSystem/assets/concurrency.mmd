%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    subgraph Riders["Two riders match at the same instant; both rank D1 first"]
        direction LR
        RA["rider A: search -> rank -> [D1, D2]"]
        RB["rider B: search -> rank -> [D1, D2]"]
    end

    D1{{"Driver D1 . status : AtomicReference&lt;DriverStatus&gt;<br/><b>tryClaim() = compareAndSet(AVAILABLE, ASSIGNED)</b>"}}:::lock

    RA -->|"tryClaim D1"| D1
    RB -->|"tryClaim D1"| D1

    D1 -->|"CAS wins"| WINA["rider A gets D1<br/>ASSIGNED"]:::win
    D1 -->|"CAS returns false"| RETRY["rider B falls through<br/>to next candidate"]:::retry

    RETRY -->|"tryClaim D2"| D2{{"Driver D2 . tryClaim()"}}:::lock
    D2 -->|"CAS wins"| WINB["rider B gets D2<br/>ASSIGNED"]:::win

    NOTE["Why no driver is double-booked: the AVAILABLE->ASSIGNED flip is a single\ncompare-and-set on the driver, so exactly one of the racing riders wins it.\nThe loser doesn't fail -- it just retries the NEXT ranked candidate.\n\nThere is NO service-wide matching lock. Search and ranking are lock-free; the\nonly contention is the CAS on the one driver two riders happen to both pick,\nso thousands of unrelated matches run fully in parallel.\n\nRollback: cancel/complete does driver.release() (ASSIGNED->AVAILABLE), so a\nfailed or finished ride returns the driver to the pool. Add a hold-timeout to\nauto-release a driver stuck ASSIGNED after a crash."]:::note

    WINA --> NOTE
    WINB --> NOTE

    classDef lock fill:#eef2ff,stroke:#3949ab,color:#1a237e;
    classDef win fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef retry fill:#fff3e0,stroke:#ef6c00,color:#7a3b00;
    classDef note fill:#fff8e1,stroke:#f9a825,color:#7a5a00;
