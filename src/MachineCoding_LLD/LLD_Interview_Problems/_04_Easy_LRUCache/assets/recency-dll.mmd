%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    TITLE["O(1) recency = HashMap index + doubly-linked list<br/><b>head = most-recently-used</b> · <b>tail = least-recently-used (evict here)</b>"]:::hdr

    subgraph IDX["index : Map&lt;K, Node&gt;  — find any node in O(1)"]
        direction LR
        iK["key → node"]:::idx
    end

    subgraph LIST["LinkedKeyList (front → back)"]
        direction LR
        HEAD(["HEAD"]):::cap
        A["A"]:::node
        B["B"]:::node
        C["C"]:::node
        TAIL(["TAIL"]):::cap
        HEAD --- A
        A <--> B
        B <--> C
        C --- TAIL
    end

    IDX -. "O(1) lookup" .-> LIST

    subgraph OPS["the three O(1) operations"]
        direction TB
        O1["<b>addFirst(D)</b> — new key on put<br/>link D at HEAD → [D, A, B, C]"]:::op
        O2["<b>moveToFirst(B)</b> — key on get/update<br/>unlink B, relink at HEAD → [B, A, C]<br/><i>this is why an LRU read is a write</i>"]:::op
        O3["<b>removeLast()</b> — evict when full<br/>pop TAIL (C), drop from index → victim = C"]:::op
        O1 --> O2 --> O3
    end

    LIST --> OPS
    FOOT["Each op = a HashMap lookup + a few pointer swaps → O(1). FIFO uses the same list but skips moveToFirst, so order stays insertion order."]:::foot
    OPS --> FOOT

    classDef hdr fill:#eef2ff,stroke:#3949ab,color:#1a237e;
    classDef node fill:#e0f0ff,stroke:#0366d6,color:#023;
    classDef cap fill:#f5f5f5,stroke:#9e9e9e,color:#424242;
    classDef idx fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
    classDef op fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef foot fill:#fff8e1,stroke:#f9a825,color:#7a5a00;
