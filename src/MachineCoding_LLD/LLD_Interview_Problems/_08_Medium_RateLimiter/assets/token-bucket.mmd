    classDef ok fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef rej fill:#fdecea,stroke:#c62828,color:#8e0000;
    classDef retry fill:#fff3e0,stroke:#ef6c00,color:#7a3d00;
