%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    START(["tryAcquire() — one permit, lock-free"]):::hdr

    subgraph STATE["state : AtomicReference&lt;(tokens, lastRefillNanos)&gt;"]
        SNAP["immutable snapshot — the unit of the CAS"]:::snap
    end

    R1["read snapshot + now = time.nanoTime()"]:::step
    R2["<b>lazy refill</b> (no background thread):<br/>tokens = min(capacity, tokens + elapsed × rate)"]:::step
    Q1{"tokens &lt; 1 ?"}
    REJECT["return false<br/><i>no write — next call recomputes from<br/>lastRefillNanos, so no refill is lost</i>"]:::rej
    CAS["compareAndSet(current, (tokens − 1, now))"]:::step
    Q2{"CAS won?"}
    ALLOW["return true"]:::ok
    RETRY["another thread won → retry"]:::retry

    START --> STATE --> R1 --> R2 --> Q1
    Q1 -- yes --> REJECT
    Q1 -- no --> CAS --> Q2
    Q2 -- yes --> ALLOW
    Q2 -- no --> RETRY
    RETRY -.-> R1

    NOTE["Token bucket allows bursts up to capacity while bounding the average.<br/>Fixed / Sliding window strategies use the SAME AtomicReference-CAS shape,<br/>swapping the snapshot for (windowId, count) / (windowId, cur, prev)."]:::note
    ALLOW --> NOTE
    REJECT --> NOTE

