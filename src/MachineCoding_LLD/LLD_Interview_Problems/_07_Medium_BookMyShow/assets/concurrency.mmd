%%{init: {'theme':'neutral', 'themeVariables': {'fontSize':'14px'}, 'flowchart': {'curve':'basis'}}}%%
flowchart TB
    subgraph Racers["N threads all want the SAME seat A1 on SHOW1"]
        direction LR
        U1["holdSeats(A1, alice)"]
        U2["holdSeats(A1, bob)"]
        U3["holdSeats(A1, carol)"]
        UN["holdSeats(A1, ...)"]
    end

    MAP{{"ConcurrentHashMap.compute( 'SHOW1::A1' )<br/><b>per-key lock held for the lambda = one ATOMIC step</b><br/>current == null OR expired ? install MY lock : keep current"}}:::lock

    U1 --> MAP
    U2 --> MAP
    U3 --> MAP
    UN --> MAP

    MAP -->|"result == my lock (identity)"| WIN["EXACTLY ONE winner<br/>seat now HELD, returns LockToken"]:::win
    MAP -->|"result == someone else's lock"| LOSE["N-1 losers<br/>throw SeatsUnavailableException"]:::lose

    NOTE["Why no double-book: 'check free THEN claim' is a single atomic remap, so there is\nno TOCTOU window for two threads to both pass the check. Identity (result == desired)\ntells each thread whether ITS lock is the one installed.\n\nMulti-seat hold: claim seats in sorted order; on ANY conflict, remove(k, myLock) the\nones already taken, giving all-or-nothing; non-blocking CAS means no deadlock is even possible.\n\nExpiry is two-layered: (1) LAZY -- compute() overwrites an expired lock, so a stale hold never\nblocks a booking even if nothing sweeps; (2) EAGER -- a ScheduledExecutor reapExpired()s for\nmemory reclaim and to notify the user their hold lapsed."]:::note

    WIN --> NOTE
    LOSE --> NOTE

    classDef lock fill:#eef2ff,stroke:#3949ab,color:#1a237e;
    classDef win fill:#e3f6e8,stroke:#2e7d32,color:#1b5e20;
    classDef lose fill:#fdecea,stroke:#c62828,color:#8e1b1b;
    classDef note fill:#fff8e1,stroke:#f9a825,color:#7a5a00;
