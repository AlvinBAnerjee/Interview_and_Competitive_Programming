flowchart TB
    IN["Incoming: BUY 12 @ 101 (aggressor)"]:::in

    subgraph Book["OrderBook — price-time priority"]
        direction TB
        subgraph Asks["ASKS  (TreeMap ascending -> best = lowest)"]
            direction TB
            A101["101 : [ s1 qty10 ]  ->  [ s2 qty5 ]   (FIFO: s1 older)"]:::ask
            A102["102 : [ s3 qty8 ]"]:::ask
        end
        subgraph Bids["BIDS  (TreeMap descending -> best = highest)"]
            direction TB
            B100["100 : [ b2 qty4 ]"]:::bid
            B99["99 : [ b1 qty7 ]"]:::bid
        end
    end

    IN -->|"1. best ask = 101 <= 101, cross"| A101
    A101 -->|"2. fill s1 fully (10), then s2 (2) -- time priority"| T["Trades:\nT1  10 @ 101  (sell s1)\nT2   2 @ 101  (sell s2)\nexecuted at MAKER price 101"]:::trade
    T -->|"3. aggressor filled (12) -> nothing rests\n(if it had leftover, a LIMIT would rest as a bid)"| DONE["s2 now 3 left @101; 102 & bids untouched"]:::done

    NOTE["Price priority: always hit the best opposite price first (101 before 102).\nTime priority: within a level, the FIFO head fills first (s1 before s2).\nMarket order: same walk but ignores the price bound and never rests its remainder.\nBest bid/ask is O(1) via TreeMap.firstEntry; level insert/remove is O(log n)."]:::note

    DONE --> NOTE

